{
  "manifest_version": 3,
  "name": "Nostalgic Startpage",
  "version": "1.1",
  "permissions": [
    "tabs",
    "bookmarks",
    "favicon",
    "storage",
    "windows",
    "history"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}